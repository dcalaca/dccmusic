{
  "buildCommand": "next build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/subscription-reminders",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/studio-generations",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/email-campaigns",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/suno-credit-alert",
      "schedule": "0 * * * *"
    }
  ]
}

# Música IA
SUNOAPI_KEY="sua-chave-suno"
MUREKA_API_KEY="sua-chave-mureka"
OPENAI_SIMPLE_COVER_IMAGE_MODEL="gpt-image-2"
OPENAI_SIMPLE_COVER_SIZE="1024x1024"
OPENAI_SIMPLE_COVER_QUALITY="low"
